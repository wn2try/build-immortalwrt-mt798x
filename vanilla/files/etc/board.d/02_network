. /lib/functions.sh
. /lib/functions/uci-defaults.sh
. /lib/functions/system.sh

board=$(board_name)

board_config_update

case $board in
ruijie,rg-x30e-pro-ubi)
	ucidef_set_interfaces_lan_wan "lan1 lan2 lan3" wan
	;;
ruijie,rg-x60-new-ubi)
	ucidef_set_interfaces_lan_wan "lan1 lan2 lan3" eth1
	;;
esac

board_config_flush

exit 0
